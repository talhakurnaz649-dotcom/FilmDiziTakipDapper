@model List<FilmDiziTakipDapper.Models.Bilet>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Biletler";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isAdmin = role == "Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2>🎫 @(isAdmin ? "Tüm Bilet Satış Kayıtları" : "Satın Aldığım Biletler")</h2>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Bilet ID</th>
                @if (isAdmin)
                {
                    <th>Kullanıcı Adı</th>
                }
                <th>İzleyici Adı Soyadı</th>
                <th>İçerik (Film/Dizi)</th>
                <th>Koltuk Numarası</th>
                <th>Ödenen Tutar</th>
                <th>Tarih</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var b in Model)
                {
                    <tr>
                        <td>#@b.Id</td>
                        @if (isAdmin)
                        {
                            <td class="fw-bold">@b.KullanıcıAdi</td>
                        }
                        <td class="fw-bold">@b.IzleyiciAdSoyad</td>
                        <td>🎬 @b.FilmAd</td>
                        <td><span class="badge bg-success px-3 py-1 fw-bold">Koltuk @b.KoltukNo</span></td>
                        <td class="fw-bold text-success">$@b.BiletFiyati.ToString("N2")</td>
                        <td>@b.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@(isAdmin ? 7 : 6)" class="text-center py-4 text-muted">Kayıtlı bilet bulunmamaktadır.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
